<?xml version="1.0" encoding="utf-8"?>
<widget id="com.shufflegolf.game" version="1.0.0"
        xmlns="http://www.w3.org/ns/widgets"
        xmlns:cdv="http://cordova.apache.org/ns/1.0">

  <name>Shuffle Golf</name>
  <description>Deck-building golf game with procedural holes</description>
  <author email="arcadia.dsg@gmail.com">Arcade Dev Studio</author>

  <content src="index.html" />

  <!-- Standard Cordova Preferences -->
  <preference name="DisallowOverscroll" value="true" />
  <preference name="EnableViewportScale" value="false" />
  <preference name="BackgroundColor" value="#ff1a2e1a" />
  <preference name="Orientation" value="landscape" />
  <preference name="FullScreen" value="true" />
  <preference name="SplashScreenDelay" value="2000" />
  <preference name="WarnOnAccess" value="true" />
  <preference name="LogLevel" value="ERROR" />

  <!-- Android-Specific Preferences -->
  <platform name="android">
    <preference name="android-minSdkVersion" value="24" />
    <preference name="android-targetSdkVersion" value="34" />
    <preference name="android-compileSdkVersion" value="34" />
    <preference name="GradlePluginKotlinVersion" value="1.9.0" />
    <preference name="AndroidHardwareAccelerated" value="true" />
    <preference name="android-useAppConfigAT" value="true" />

    <!-- AdMob App ID — Replace with your app ID from AdMob console -->
    <preference name="ADMOB_APP_ID" value="ca-app-pub-5076664753284203~6230186799" />

    <!-- Launcher Icons -->
    <icon src="res/android/mdpi.png" density="mdpi" />
    <icon src="res/android/hdpi.png" density="hdpi" />
    <icon src="res/android/xhdpi.png" density="xhdpi" />
    <icon src="res/android/xxhdpi.png" density="xxhdpi" />
    <icon src="res/android/xxxhdpi.png" density="xxxhdpi" />

    <!-- Splash Screen -->
    <splash src="res/android/splash.png" density="port-ldpi" />
    <splash src="res/android/splash.png" density="port-mdpi" />
    <splash src="res/android/splash.png" density="port-hdpi" />
    <splash src="res/android/splash.png" density="port-xhdpi" />
  </platform>

  <!-- Permissions -->
  <access origin="*" />
  <allow-navigation href="*" />

  <!-- Allow Google domains for AdMob, Analytics, etc. -->
  <allow-intent href="https://*.google.com/*" />
  <allow-intent href="https://*.googlesyndication.com/*" />
  <allow-intent href="https://*.doubleclick.net/*" />
  <allow-intent href="https://googleadservices.com/*" />

  <!-- Cordova Plugins -->
  <plugin name="cordova-plugin-whitelist" spec="^1.3.4" />
  <plugin name="cordova-plugin-splashscreen" spec="^6.0.2" />
  <plugin name="cordova-plugin-statusbar" spec="^2.4.3" />
  <plugin name="cordova-plugin-device" spec="^2.1.0" />

  <!-- Google Mobile Ads Plugin (AdMob) -->
  <!-- Note: Choose ONE of the following:
       - cordova-plugin-admob-free (legacy, less maintained)
       - google-mobile-ads-cordova-plugin (official, recommended)
       - cordova-admob-plus (community-maintained)
  -->
  <plugin name="cordova-plugin-admob-free" spec="^0.20.0">
    <variable name="ADMOB_APP_ID" value="ca-app-pub-5076664753284203~6230186799" />
  </plugin>

  <!-- Alternative: Google's Official Plugin (uncomment to use instead) -->
  <!-- <plugin name="google-mobile-ads-cordova-plugin" spec="~5.1.0">
    <variable name="APP_ID_ANDROID" value="ca-app-pub-5076664753284203~6230186799" />
  </plugin> -->

</widget>
